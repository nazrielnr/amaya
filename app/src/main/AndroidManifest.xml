<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network permissions for AI API communication -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- File access for code editing (Android 11+ requires special handling) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    
    <!-- Foreground service for long-running operations -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Notifications (required Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Exact alarms for cron job reminders (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
        tools:ignore="ExactAlarm" />

    <!-- Reschedule alarms after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Camera for QR scanning -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Bluetooth for sync (Android 12+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    
    <!-- Legacy Bluetooth for older versions -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />

    <application
        android:name=".AmayaApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Amaya"
        android:requestLegacyExternalStorage="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="34">
        
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- New modular local activities -->
        <activity
            android:name=".ui.activities.agent.local.LocalAgentActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya" />
        
        <activity
            android:name=".ui.activities.chat.local.LocalChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya" />
        
        <activity
            android:name=".ui.activities.mcp.local.LocalMcpActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya" />
        
        <activity
            android:name=".ui.activities.cronjob.local.LocalCronJobActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya" />
        
        <activity
            android:name=".ui.activities.persona.local.LocalPersonaActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya" />
        
        <activity
            android:name=".ui.activities.project.local.LocalProjectActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya" />
        
        <activity
            android:name=".ui.activities.settings.local.LocalSettingsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya" />

        <!-- New modular remote activities -->
        <activity
            android:name=".ui.activities.agent.remote.RemoteAgentActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya" />
        
        <activity
            android:name=".ui.activities.chat.remote.RemoteChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya" />
        
        <activity
            android:name=".ui.activities.mcp.remote.RemoteMcpActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya" />
        
        <activity
            android:name=".ui.activities.cronjob.remote.RemoteCronJobActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya" />
        
        <activity
            android:name=".ui.activities.persona.remote.RemotePersonaActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya" />
        
        <activity
            android:name=".ui.activities.project.remote.RemoteProjectActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya" />
        
        <activity
            android:name=".ui.activities.settings.remote.RemoteSettingsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya" />
        
        
        <!-- File provider for secure file sharing -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Disable WorkManager default init; AmayaApplication provides HiltWorkerFactory -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="@string/androidx_startup"
                tools:node="remove" />
        </provider>

        <!-- Google Play Services unbundled ML Kit requirement -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="barcode" />
        
        <!-- Foreground service for AI operations -->
        <service
            android:name=".service.AiOperationService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- BroadcastReceiver for cron job alarms -->
        <receiver
            android:name=".service.CronJobReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.amaya.intelligence.CRON_JOB_FIRE" />
            </intent-filter>
        </receiver>

        <!-- BroadcastReceiver to reschedule alarms after reboot -->
        <!-- FIX 2: android:exported="true" is required for BOOT_COMPLETED receivers (system sends it),
             but restrict with android:permission so only the system can trigger it. -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>
        
        <activity
            android:name=".ui.activities.remote.RemoteSessionActivity"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya"
            android:exported="false" />

        <activity
            android:name=".ui.activities.remote.RemoteChatActivity"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya"
            android:exported="false" />

        <activity
            android:name=".ui.activities.remote.RemoteProjectActivity"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya"
            android:exported="false" />

        <activity
            android:name=".ui.activities.remote.QrScannerActivity"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Amaya"
            android:exported="false" />

        <service
            android:name="com.amaya.intelligence.impl.ide.antigravity.client.RemoteSessionForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>

</manifest>
